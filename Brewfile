# Digital Archive Maker - Essential Dependencies
# This file ensures reproducible installations across different systems

# Core audio/CD ripping tools
brew "abcde"
brew "flac"
brew "cd-discid"
brew "libcdio"
brew "libcdio-paranoia"

# Video processing tools
brew "ffmpeg"
brew "handbrake"
brew "libdvdcss"
brew "mkvtoolnix"

# Image processing
brew "imagemagick"

# Data processing
brew "jq"

# Network tools
brew "curl"
brew "wget"

# Node.js for GUI
brew "node"
