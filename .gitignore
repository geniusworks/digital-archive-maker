# Ignore local directories (but keep .gitkeep files)
_archive/
_install/
venv/
log/**
cache/**
config/**
.local/

# Exception: allow .gitkeep files to track empty directories
!log/.gitkeep
!log/**/.gitkeep
!cache/.gitkeep
!config/.gitkeep

# Ignore specific file (legacy path, kept for compatibility)
# prince-lovesexy/Lovesexy.flac

# Ignore local env and OS files
.env
.DS_Store
Icon*

# Python caches
__pycache__/
*.egg-info/
.venv/
.coverage
htmlcov/
.pytest_cache/

# Ignore text files
albums.txt
artists.txt
only_in_new.txt
only_in_old.txt

# Ignore video processing temporary files
.backfill_ocr_*
*.tmp.mp4
*.bak

# Ignore CD processing config
.abcde.conf

# Ignore custom sync configuration
bin/sync/sync-config.yaml

# Ignore specialized album source files
bin/music/specialized/prince-lovesexy/Lovesexy.flac