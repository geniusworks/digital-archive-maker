# Environment variables for this project
# Copy to .env and source in your shell init, or let the Makefile load it automatically.

# Root directory for all media library content (CDs, DVDs, Blu-rays, etc.)
# Used by bin/rip_video.sh and by abcde via .abcde.conf.example
LIBRARY_ROOT=/Volumes/Data/Media/Library

# AcoustID API key for audio fingerprint lookups (used by fix_track.py)
ACOUSTID_API_KEY=your_acoustid_api_key_here

# MusicBrainz lookup for CD ripping (used by abcde via .abcde.conf)
# Set to "true" to enable MusicBrainz metadata lookup for CDs
# Set to "false" to disable MusicBrainz lookup
MUSICBRAINZ_LOOKUP=true

# Genius API token for lyrics lookup (used by bin/music/download_lyrics.py)
# Get a free token at: https://genius.com/api-clients
GENIUS_API_TOKEN=your_genius_api_token_here

# Spotify API credentials for explicit content tagging (used by bin/tag-explicit-mb.py)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# OMDb API key for movie rating lookups (used by bin/tag-movie-ratings.py)
# Get these from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# TMDb credentials for movie/show metadata lookups (used by bin/tag-movie-metadata.py,
# bin/tag-movie-ratings.py, and bin/tag-show-metadata.py)
# Create these at https://www.themoviedb.org/settings/api
# Prefer TMDB_READ_ACCESS_TOKEN when available; TMDB_API_KEY is supported as a fallback.
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# HandBrake encoding settings for video ripping (used by bin/video/rip_video.py)
# Quality: Higher number = lower quality but faster encoding (18-28, default 28 for speed)
# Preset: Must match HandBrake preset names exactly (e.g., "Fast 1080p30", "Very Fast 1080p30")
# Tune: Optional tuning for specific content (film, animation, grain, etc.)
HB_QUALITY=28
HB_PRESET=Fast 1080p30
# HB_TUNE=film

# Disc ejection after ripping (used by bin/video/rip_video.py)
# Set to "true", "1", or "yes" to automatically eject disc after processing
EJECT_DISC=false

# Track selection for video ripping (used by bin/video/rip_video.py)
# Set to "true", "1", or "yes" to process all tracks instead of just the main feature
FORCE_ALL_TRACKS=false

# Streaming optimization for Jellyfin/Plex compatibility (used by bin/video/rip_video.py)
# Set to "true", "1", or "yes" to enable additional streaming optimizations
STREAMING_OPTIMIZE=true

# Language preferences for video ripping (used by bin/video/rip_video.py)
# Use 2-letter ISO 639-1 codes (e.g., "en", "fr", "es", "de", "ja")
# LANG_AUDIO: Preferred audio track language
# LANG_SUBTITLES: Preferred subtitle track language
# LANG_VIDEO: Preferred video/movie language (for selecting main feature when disc has multiple language versions)
LANG_AUDIO=en
LANG_SUBTITLES=en
LANG_VIDEO=en

# Audio codec preference (used by bin/video/rip_video.py)
# If set, prefer this codec over others when available. Options: ac3, eac3, dts, aac, mp3, pcm, truehd, flac
# Leave empty to use automatic compatibility-based selection
# PREFERRED_AUDIO_CODEC=

# Subtitle preference (used by bin/video/rip_video.py)
# If set, prefer this type. Options: srt (soft subtitles), pgs (image subs), burn (burn into video)
# Leave empty to use automatic selection based on available subtitle types
# PREFERRED_SUBTITLE_TYPE=