# abcde sample configuration for CD ripping to FLAC
# Copy to ~/.abcde.conf and adjust as needed

# Output format and location
# OUTPUTDIR can be centralized via RIPS_ROOT (see .env.sample). Falls back to /Volumes/Data/Media/Library
OUTPUTDIR="${RIPS_ROOT:-/Volumes/Data/Media/Library}/CDs"
OUTPUTTYPE="flac"

# Actions pipeline
ACTIONS=cddb,getalbumart,encode,tag,move,playlist,clean

# Metadata lookup via MusicBrainz
MUSICBRAINZ_LOOKUP=y
CDDBLOCALDIR="$HOME/.cddb"

# Cover art
COVERFILE="cover.jpg"

# Output
OUTPUTFORMAT='${ARTISTFILE}/${ALBUMFILE}/${TRACKNUM} - ${TRACKFILE}'
VAOUTPUTFORMAT='Various/${ALBUMFILE}/${TRACKNUM} - ${TRACKFILE}'

# Behavior
KEEPWAVS=n
KEEPDIR=n
INTERACTIVE=n
NICEVALUE=10
FLACOPTS='--best --verify'

# Eject CD when done (abcde built-in behavior)
EJECTCD=y

# Enable M3U playlists
PLAYLISTS=y
PLAYLISTFORMAT='${ARTISTFILE}/${ALBUMFILE}/${ALBUMFILE}.m3u8'
VAPLAYLISTFORMAT='Various/${ALBUMFILE}/${ALBUMFILE}.m3u8'

# ReplayGain
USERPLAYGAIN=y

# Clean filename handling
mungefilename ()
{
    echo "$@" | sed \
        -e 's/[\/\\:*?"<>|]/_/g' \
        -e 's/  */ /g' \
        -e 's/^ *//' \
        -e 's/ *$//'
}

post_encode ()
{
    for fmt in "$PLAYLISTFORMAT" "$VAPLAYLISTFORMAT"; do
        [ -z "$fmt" ] && continue
        pl_rel="$(eval echo "$fmt")"
        pl_path="$OUTPUTDIR/$pl_rel"
        [ -f "$pl_path" ] || continue
        if ! head -n 1 "$pl_path" 2>/dev/null | grep -q '^#EXTM3U$'; then
            tmp="$(mktemp)"
            printf '%s\n' '#EXTM3U' > "$tmp"
            cat "$pl_path" >> "$tmp"
            mv "$tmp" "$pl_path"
        fi
    done
}
